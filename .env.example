# ─────────────────────────────────────────────────────────────────────────────
# Synthetic Vision — environment configuration
# Copy this file to `.env` and adjust as needed:  cp .env.example .env
# Every key below maps to internal/config.Config (see SPEC §3).
# ─────────────────────────────────────────────────────────────────────────────

# HTTP listen port.
PORT=8080

# Directory for the SQLite database and generated images (mounted as a volume).
DATA_DIR=./data

# JWT signing secret used for session tokens.
# IMPORTANT: keep this STABLE across restarts/rebuilds. Changing it invalidates
# every existing session token and forces all users to log in again.
# Generate a strong value for production, e.g. `openssl rand -hex 32`.
JWT_SECRET=dev-insecure-change-me

# Session token lifetime, in hours (default 168 = 7 days).
JWT_TTL_HOURS=168

# Image generation backend: "mock" (built-in deterministic abstract art) or
# "openai" (any OpenAI-compatible /v1/images/generations endpoint).
IMAGE_PROVIDER=mock

# OpenAI-compatible provider settings (only used when IMAGE_PROVIDER=openai).
# Leave blank for the default mock provider.
OPENAI_BASE_URL=https://api.xjy.de5.net
OPENAI_API_KEY=
# gpt-image-1 accepts arbitrary WxH sizes. NOTE: dall-e-3 only accepts
# 1024x1024 / 1792x1024 / 1024x1792 — non-1:1 requests will fail with it.
IMAGE_MODEL=gpt-image-2

# Artificial delay (ms) the mock provider sleeps to simulate synthesis time.
MOCK_DELAY_MS=2500

# Default admin account, seeded on first boot.
ADMIN_EMAIL=admin@synthetic.ai
ADMIN_PASSWORD=synthavision

# Number of background generation worker goroutines.
GEN_WORKERS=4

# Seed demo users (matching the design screenshots) on an empty database.
SEED_DEMO_USERS=true
